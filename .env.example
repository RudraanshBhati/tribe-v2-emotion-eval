# Copy this file to .env and fill in your keys
# cp .env.example .env

# ElevenLabs API key (required for generate_audio_elevenlabs.py)
# Free tier: 10,000 chars/month — https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# HuggingFace token (required for load_mosei.py and facebook/tribev2 model download)
# Generate at: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here
